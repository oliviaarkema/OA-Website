<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<title>Website Design & Development | Olivia Arkema</title>

<meta name="description" content="Website design and development for small businesses. Fast, mobile-friendly, and built to convert.">

<link rel="icon" href="green_bow.png">

<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:wght@400;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

<script src="https://cdn.tailwindcss.com"></script>

<style>
body { font-family: 'Inter', sans-serif; background:#ebe3db; }
h1,h2,h3 { font-family: 'Noto Serif', serif; }
</style>
</head>

<body>

<!-- NAV (fixed to homepage links) -->
<nav class="fixed w-full bg-white/90 backdrop-blur z-50">
  <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
    <a href="/" class="font-bold text-xl">OA</a>

    <div class="hidden md:flex space-x-8 text-sm">
      <a href="/#home">Home</a>
      <a href="/#services">Work</a>
      <a href="/#clients">Projects</a>
      <a href="/#featuredwork">Writing</a>
      <a href="/#contact">Contact</a>
    </div>

    <button id="menuBtn" class="md:hidden flex flex-col w-8 h-8 justify-center items-center">
      <span class="w-5 h-[2px] bg-black mb-1"></span>
      <span class="w-5 h-[2px] bg-black mb-1"></span>
      <span class="w-5 h-[2px] bg-black"></span>
    </button>
  </div>

  <div id="mobileMenu" class="hidden md:hidden px-6 pb-4 border-t border-[#e6dfd7]">
    <div class="flex flex-col space-y-4 text-sm pt-4">
      <a href="/#home">Home</a>
      <a href="/#services">Work</a>
      <a href="/#clients">Projects</a>
      <a href="/#featuredwork">Writing</a>
      <a href="/#contact">Contact</a>
    </div>
  </div>
</nav>

<script>
menuBtn.addEventListener("click", () => {
  mobileMenu.classList.toggle("hidden");
});
</script>

<!-- HERO -->
<section class="min-h-[75vh] flex items-center text-center">
  <div class="max-w-4xl mx-auto px-6">

    <h1 class="text-5xl md:text-6xl mb-4">
      Websites that actually work
    </h1>

    <p class="text-lg text-[#8a8175] max-w-xl mx-auto mb-6">
      Fast, mobile-friendly websites built to convert visitors into customers.
    </p>

    <a href="/#contact" class="px-8 py-3 bg-[#5f849c] text-white rounded-lg">
      Get a website
    </a>

  </div>
</section>

<!-- INTRO -->
<section class="py-16 bg-white">
  <div class="max-w-3xl mx-auto px-6 text-center">

    <p class="text-[#5f5a52] leading-relaxed">
      Many businesses rely only on social media—but that means missing out on search traffic, credibility, and long-term growth.
      A strong website gives you control, visibility, and a place customers can trust.
    </p>

  </div>
</section>

<!-- WEBSITE TYPES -->
<section class="py-20 bg-[#f7f3ee]">
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-10">
      <h2 class="text-4xl mb-3">What kind of website do you need?</h2>
      <p class="text-[#8a8175]">
        Built around your business goals—not a template.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">

      <div class="bg-white border border-[#e6dfd7] rounded-xl p-6">
        <h3 class="mb-2">Service websites</h3>
        <p class="text-[#8a8175] text-sm">
          Clean, professional sites that showcase your work and make it easy to get in touch.
        </p>
      </div>

      <div class="bg-white border border-[#e6dfd7] rounded-xl p-6">
        <h3 class="mb-2">E-commerce</h3>
        <p class="text-[#8a8175] text-sm">
          Sell products online with secure checkout and simple management.
        </p>
      </div>

      <div class="bg-white border border-[#e6dfd7] rounded-xl p-6">
        <h3 class="mb-2">Booking & scheduling</h3>
        <p class="text-[#8a8175] text-sm">
          Let customers book appointments easily without back-and-forth.
        </p>
      </div>

      <div class="bg-white border border-[#e6dfd7] rounded-xl p-6">
        <h3 class="mb-2">SEO & content sites</h3>
        <p class="text-[#8a8175] text-sm">
          Blog-driven sites that attract traffic and build authority over time.
        </p>
      </div>

      <div class="bg-white border border-[#e6dfd7] rounded-xl p-6">
        <h3 class="mb-2">Custom builds</h3>
        <p class="text-[#8a8175] text-sm">
          Fully tailored websites with advanced functionality.
        </p>
      </div>

      <div class="bg-white border border-[#e6dfd7] rounded-xl p-6">
        <h3 class="mb-2">Not sure yet?</h3>
        <p class="text-[#8a8175] text-sm">
          I’ll help you figure out what actually makes sense for your business.
        </p>
      </div>

    </div>

  </div>
</section>

<!-- PRINCIPLES -->
<section class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-10">
      <h2 class="text-4xl mb-3">What makes a good website</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">

      <div class="bg-[#faf8f6] border border-[#e6dfd7] rounded-xl p-6">
        <h3 class="mb-2">Fast</h3>
        <p class="text-[#8a8175] text-sm">
          Loads quickly and performs well on all devices.
        </p>
      </div>

      <div class="bg-[#faf8f6] border border-[#e6dfd7] rounded-xl p-6">
        <h3 class="mb-2">Mobile-friendly</h3>
        <p class="text-[#8a8175] text-sm">
          Designed for how people actually browse today.
        </p>
      </div>

      <div class="bg-[#faf8f6] border border-[#e6dfd7] rounded-xl p-6">
        <h3 class="mb-2">Easy to use</h3>
        <p class="text-[#8a8175] text-sm">
          Clear navigation and simple user experience.
        </p>
      </div>

    </div>

  </div>
</section>

<!-- CTA -->
<section class="py-16 bg-[#23424c] text-white text-center">
  <div class="max-w-2xl mx-auto px-6">

    <h2 class="text-3xl mb-4">Let’s build something that works</h2>

    <p class="text-[#dae4eb] mb-6">
      If you need a website—or want to improve your current one—let’s talk.
    </p>

    <a href="/#contact" class="px-8 py-3 bg-[#5f849c] rounded-lg">
      Get in touch
    </a>

  </div>
</section>

</body>
</html>
