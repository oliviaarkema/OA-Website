<section class="py-16 bg-white">
  <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">

    <div>
      <h2 class="text-3xl mb-4">Results-Driven Marketing</h2>
      <p class="text-[#8a8175] leading-relaxed">
