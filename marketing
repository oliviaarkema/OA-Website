<!-- CREATIVE (darker band) -->
<section class="py-20 bg-[#23424c] text-white">
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-10">
      <h2 class="text-4xl mb-3">Creative & Execution</h2>
      <p class="text-[#dae4eb]">
        Bringing strategy to life across channels.
