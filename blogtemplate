  </div>

  <div id="mobileMenu" class="hidden px-6 pb-4 bg-white border-t">
    <div class="flex flex-col space-y-4 text-sm pt-4">
      <a href="/#home">Home</a>
      <a href="/#services">Work</a>
      <a href="/#clients">Projects</a>
      <a href="/#featuredwork">Writing</a>
      <a href="/#contact">Contact</a>
    </div>
  </div>
</header>

<script>
menuBtn.addEventListener("click", () => {
  mobileMenu.classList.toggle("hidden");
});
</script>

<!-- SPACER -->
<div class="h-24"></div>

<!-- BLOG -->
<main class="px-6 py-12">
  <article class="max-w-3xl mx-auto card p-8 md:p-10">

    <!-- HEADER -->
    <header class="mb-8 text-center">
      <p class="text-sm mb-2" style="color: var(--text-muted);">[CATEGORY]</p>

      <h1 class="text-3xl md:text-4xl mb-3" style="color: var(--primary-color);">
        [BLOG TITLE]
      </h1>

      <p class="text-sm" style="color: var(--text-muted);">
        By Olivia Arkema • [DATE]
      </p>
    </header>

    <!-- IMAGE -->
    <figure class="mb-8">
      <img src="[IMAGE PATH]" alt="[IMAGE ALT]" class="rounded-lg mx-auto">
    </figure>

    <!-- CONTENT (PASTE BLOG HERE — DO NOT STYLE) -->
    <div class="space-y-6 leading-relaxed">

      <!-- START BLOG CONTENT -->

      <p>Your content goes here...</p>

      <h2 style="color: var(--secondary-color);">Section Heading</h2>

      <p>More content...</p>

      <!-- END BLOG CONTENT -->

    </div>

  </article>
</main>

<!-- CONTACT / FOOTER (DO NOT EDIT) -->
<section id="contact" class="py-20 text-white text-center" style="background: var(--secondary-color);">
  <div class="max-w-2xl mx-auto px-6">

    <h2 class="text-3xl mb-6">Get in touch</h2>

    <p class="mb-8" style="color: rgba(255,255,255,0.8);">
      Need a website or help making sense of data?
    </p>

    <a href="mailto:livarkema@gmail.com" class="button primary">
      Email me
    </a>

    <div class="mt-12 mb-6" style="height:1px; background: rgba(255,255,255,0.2);"></div>

    <p class="text-sm" style="color: rgba(255,255,255,0.7);">
      &copy; <span id="year"></span> Olivia Arkema
    </p>

  </div>
</section>

<script>
document.getElementById('year').textContent = new Date().getFullYear();
</script>

</body>
</html>
