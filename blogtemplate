<body class="font-[Inter]" style="background: var(--tertiary-color); color: var(--text-dark);">

<!-- NAV (DO NOT EDIT) -->
<header id="navbar" class="fixed w-full z-50 backdrop-blur border-b" style="background: rgba(255,255,255,0.9); border-color: rgba(0,0,0,0.05);">
  <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">

    <a href="/" class="text-xl font-bold" style="color: var(--primary-color);">OA</a>

    <nav class="hidden md:flex space-x-8 text-sm">
      <a href="/#home">Home</a>
      <a href="/#services">Work</a>
      <a href="/#clients">Projects</a>
      <a href="/#featuredwork">Writing</a>
      <a href="/#contact">Contact</a>
    </nav>

