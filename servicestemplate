<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Service Name — Olivia Arkema</title>
  <meta name="description" content="Short, compelling summary of this service and the outcome it delivers." />
  <link rel="canonical" href="https://oliviaarkema.com/services/service-slug" />

  <style>
    /* ==== Minimal design system ==== */
    :root{
      --bg:#faf7f2; --ink:#393831; --muted:#9e9383; --blue:#5f849c; --deep:#23424c; --wash:#dae4eb;
      --max:1100px;
    }
    html,body{margin:0;padding:0}
    body{background:var(--bg);color:var(--ink);font:16px/1.6 system-ui,-apple-system,Segoe UI,Roboto,Inter,Arial,sans-serif}
    a{color:var(--deep);text-decoration:none}
    a:hover{text-decoration:underline}
    .wrap{max-width:var(--max);margin:0 auto;padding:0 20px}
    .section{padding:40px 0}
    h1,h2,h3{margin:0 0 .5rem}
    h1{font-size:clamp(28px,4vw,44px);line-height:1.2;color:var(--deep)}
    h2{font-size:clamp(20px,3vw,28px);color:var(--blue)}
    h3{font-size:clamp(18px,2.3vw,22px);color:var(--deep)}
    p{margin:0 0 1rem}
    .btn{display:inline-block;background:var(--blue);color:#fff;border-radius:10px;padding:.7rem 1rem}
    .btn:hover{filter:brightness(.95)}
    .pill{display:inline-block;background:var(--wash);color:var(--deep);border-radius:9999px;padding:.35rem .7rem;font-size:.85rem}
    .grid{display:grid;gap:16px}
    .grid-2{grid-template-columns:repeat(2,minmax(0,1fr))}
    .grid-3{grid-template-columns:repeat(3,minmax(0,1fr))}
    @media (max-width:860px){.grid-2,.grid-3{grid-template-columns:1fr}}
    .card{background:#fff;border:2px solid var(--blue);border-radius:14px;padding:18px}
    .list{padding-left:1rem}
    .list li{margin:.35rem 0}
    /* Long-form: single column → two columns on wide screens */
    .longform{column-gap:32px}
    @media (min-width:1100px){
      .longform{column-count:2}
      .longform > *{break-inside:avoid}
    }

    /* Simple header/footer */
    header.nav{position:sticky;top:0;background:#fff;border-bottom:1px solid #e8e4de;z-index:10}
    .nav-row{display:flex;align-items:center;justify-content:space-between;padding:14px 0}
    .nav-links{display:flex;gap:18px;flex-wrap:wrap}
    footer{background:#393831;color:#9e9383}
    footer a{color:#9e9383}
  </style>
</head>
<body>

  <!-- Header (simple, no JS) -->
  <header class="nav">
    <div class="wrap nav-row">
      <a href="/" style="font-weight:700;color:var(--deep);font-size:20px">OA</a>
      <nav class="nav-links">
        <a href="/#services">Services</a>
        <a href="/#featuredwork">Work</a>
        <a href="/#contact">Contact</a>
      </nav>
    </div>
  </header>

  <!-- HERO -->
  <section class="section">
    <div class="wrap">
      <span class="pill">Signature Service</span>
      <h1>Service Name That States the Outcome</h1>
      <p style="max-width:70ch;color:var(--muted)">
        A concise, medium-length paragraph (2–4 sentences) framing the problem, your approach,
        and the outcome — without fluff.
      </p>
      <div style="margin-top:14px;display:flex;gap:10px;flex-wrap:wrap">
        <a href="#inquiry" class="btn">Start a Project</a>
        <a href="#packages" class="pill">See Packages</a>
      </div>
    </div>
  </section>

  <!-- VALUE (What you get) -->
  <section class="section" style="padding-top:0">
    <div class="wrap grid grid-2">
      <div>
        <h2>What You Get</h2>
        <p style="color:var(--muted)">Medium-length copy describing deliverables and outcomes at a glance.</p>
      </div>
      <div class="grid grid-2">
        <div class="card"><strong>Deliverable #1</strong><br><span style="color:var(--muted)">Short value statement.</span></div>
        <div class="card"><strong>Deliverable #2</strong><br><span style="color:var(--muted)">Short value statement.</span></div>
        <div class="card"><strong>Deliverable #3</strong><br><span style="color:var(--muted)">Short value statement.</span></div>
        <div class="card"><strong>Deliverable #4</strong><br><span style="color:var(--muted)">Short value statement.</span></div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section" style="padding-top:0">
    <div class="wrap">
      <h2>How It Works</h2>
      <div class="grid grid-4" style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px">
        <div class="card"><h3>01 · Discover</h3><p style="color:var(--muted)">Short description.</p></div>
        <div class="card"><h3>02 · Design</h3><p style="color:var(--muted)">Short description.</p></div>
        <div class="card"><h3>03 · Implement</h3><p style="color:var(--muted)">Short description.</p></div>
        <div class="card"><h3>04 · Optimize</h3><p style="color:var(--muted)">Short description.</p></div>
      </div>
    </div>
  </section>

  <!-- LONG-FORM (lots of text; auto two columns on wide screens) -->
  <section class="section" id="longform">
    <div class="wrap">
      <h2>Deep Dive</h2>
      <div class="longform" style="max-width:85ch">
        <p>Opening paragraph for long-form content…</p>
        <p>More detail, context, and examples. Keep paragraphs tight and scannable.</p>
        <h3>Subsection Heading</h3>
        <p>Explain the method, timelines, or case study details here.</p>
        <p>Continue with as much text as you need. On large screens this flows into two columns.</p>
        <h3>Results / Outcomes</h3>
        <ul class="list">
          <li>Outcome 1 with a measurable stat.</li>
          <li>Outcome 2 with a client-friendly phrasing.</li>
          <li>Outcome 3 with timeline expectations.</li>
        </ul>
        <p>Wrap-up paragraph with a lead-in to the CTA below.</p>
      </div>
    </div>
  </section>

  <!-- PACKAGES (optional) -->
  <section class="section" id="packages">
    <div class="wrap grid grid-3">
      <div class="card">
        <h3>Starter</h3>
        <p style="color:var(--muted)">Who this is for + quick value.</p>
        <a href="#inquiry" class="btn" style="margin-top:8px">Request Quote</a>
      </div>
      <div class="card">
        <h3>Growth</h3>
        <p style="color:var(--muted)">Who this is for + quick value.</p>
        <a href="#inquiry" class="btn" style="margin-top:8px">Request Quote</a>
      </div>
      <div class="card">
        <h3>Custom</h3>
        <p style="color:var(--muted)">Who this is for + quick value.</p>
        <a href="#inquiry" class="btn" style="margin-top:8px">Request Quote</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" id="inquiry" style="padding-top:0">
    <div class="wrap card" style="display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap">
      <div>
        <h2>Ready to get started?</h2>
        <p style="color:var(--muted);max-width:60ch">Tell me about your goals, timeline, and budget. I’ll follow up with next steps.</p>
      </div>
      <a href="mailto:hello@oliviaarkema.com?subject=Project%20Inquiry" class="btn">Email Olivia</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="section" style="padding:28px 0">
    <div class="wrap" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px">
      <small>© <span id="year"></span> Olivia Arkema</small>
      <div style="display:flex;gap:14px"><a href="/privacy">Privacy</a><a href="/terms">Terms</a></div>
    </div>
  </footer>

  <script>
    document.getElementById('year').textContent = new Date().getFullYear();
  </script>
</body>
</html>
