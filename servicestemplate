  <!-- ===== Minimal JS ===== -->
  <script>
    // Nav hide/show on scroll (optional)
    let lastScrollTop = 0;
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', function () {
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
      if (scrollTop > lastScrollTop && scrollTop > 100) { navbar.style.transform = 'translateY(-100%)'; }
      else { navbar.style.transform = 'translateY(0)'; }
      lastScrollTop = scrollTop;
    });

    // Mobile menu toggle
    function toggleMenu(){ document.getElementById('mobile-menu').classList.toggle('hidden'); }

    // Footer year
    document.getElementById('year').textContent = new Date().getFullYear();
  </script>
