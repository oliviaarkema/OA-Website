<!DOCTYPE html>
<html lang="en">
<head>
  <!-- ===== Basic SEO ===== -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title><!-- SEO: Page Title (60–65 chars) -->Your Post Title | Site Name</title>
  <meta name="description" content="<!-- SEO: 150–160 chars meta description for this post. -->" />
  <link rel="canonical" href="https://example.com/blog/your-post-slug" />

  <!-- ===== Open Graph ===== -->
  <meta property="og:type" content="article" />
  <meta property="og:title" content="Your Post Title | Site Name" />
  <meta property="og:description" content="<!-- Same as description or tailored for social. -->" />
  <meta property="og:url" content="https://example.com/blog/your-post-slug" />
  <meta property="og:image" content="https://example.com/path/to/featured-image.jpg" />
  <meta property="og:site_name" content="Site Name" />

  <!-- ===== Twitter Cards ===== -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Your Post Title | Site Name" />
  <meta name="twitter:description" content="<!-- 200 chars works well on Twitter. -->" />
  <meta name="twitter:image" content="https://example.com/path/to/featured-image.jpg" />
  <meta name="twitter:site" content="@YourHandle" />

  <!-- ===== Article Structured Data (JSON-LD) ===== -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "Your Post Title",
    "description": "Short description (plain text).",
    "image": ["https://example.com/path/to/featured-image.jpg"],
    "datePublished": "2025-08-18T12:00:00-04:00",
    "dateModified": "2025-08-18T12:00:00-04:00",
    "author": { "@type": "Person", "name": "Author Name" },
    "publisher": {
      "@type": "Organization",
      "name": "Site/Brand Name",
      "logo": { "@type": "ImageObject", "url": "https://example.com/path/to/logo.png" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://example.com/blog/your-post-slug" }
  }
  </script>

  <!-- ===== Styles ===== -->
  <link rel="stylesheet" href="/style.css" />
  <style>
    /* Page-specific helpers (kept minimal) */
    .article-hero{ background: linear-gradient(180deg, rgba(35,66,76,.75), rgba(35,66,76,.55)), center/cover no-repeat var(--night); min-height: 48vh; display:grid; place-items:center; padding: 7rem 1.5rem 3rem; text-align:center; }
    .article-wrap{ max-width: 980px; margin: 0 auto; padding: 2rem 1.25rem; }
    .article-meta{ color: var(--moss); font-size: .9375rem; display:flex; gap: .75rem; justify-content:center; flex-wrap:wrap; }
    .feature-img{ border: 2px solid var(--accent); border-radius: .75rem; overflow: hidden; box-shadow: var(--shadow-sm); }
    .prose{ font-size: 1.125rem; line-height: 1.8; }
    .prose h2, .prose h3{ margin-top: 2.25rem; }
    .pull-quote{ font-size: 1.35rem; padding: 1.25rem 1.5rem; border-left: 4px solid var(--accent); background: var(--mist); border-radius: .5rem; margin: 2rem 0; }
    .toc{ background: var(--white); border: 2px solid var(--accent); border-radius: .75rem; padding: 1rem 1.25rem; box-shadow: var(--shadow-sm); }
    .tag{ display:inline-block; padding:.35rem .75rem; border-radius: 9999px; background: color-mix(in srgb, var(--accent) 18%, white); color: var(--ink); font-size:.875rem; }
    .article-footer{ display:flex; gap:1rem; justify-content:space-between; align-items:center; flex-wrap:wrap; margin-top: 2.5rem; }
    .share a{ text-decoration:none; color: var(--stone); margin-right:.75rem; }
    .newsletter{ background: var(--night); color: var(--mist); border-radius: 1rem; padding: 1.25rem; display:flex; gap:.75rem; flex-wrap:wrap; align-items:center; }
    .newsletter input{ flex:1 1 260px; padding: .75rem 1rem; border-radius:.5rem; border:2px solid var(--mist); background: transparent; color: var(--mist); }
    .prev-next{ display:flex; gap:1rem; flex-wrap:wrap; }
    .prev-next a{ text-decoration:none; border:2px solid var(--accent); padding: .75rem 1rem; border-radius:.75rem; }
    .hero-title{ color: var(--white); }
  </style>
</head>

<body>
  <!-- ===== Site Header / Nav ===== -->
  <header id="navbar">
    <div class="nav-bar article-wrap" style="padding: .75rem 1.25rem;">
      <a class="nav-brand" href="/">
        <img class="nav-logo" src="/assets/logo.svg" alt="" />
        Site Name
      </a>

      <div class="nav-right">
        <nav class="nav-links" aria-label="Primary">
          <a href="/about">About</a>
          <a href="/services">Services</a>
          <a href="/blog" aria-current="page">Blog</a>
          <a href="/contact">Contact</a>
        </nav>

        <!-- Mobile hamburger (right-aligned) -->
        <button class="nav-toggle" id="navToggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
          <!-- Simple icon -->
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <nav id="mobile-menu" class="mobile-menu hidden" aria-label="Mobile Primary">
      <div class="article-wrap">
        <a href="/about">About</a>
        <a href="/services">Services</a>
        <a href="/blog">Blog</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>
  </header>

  <main>
    <!-- ===== Article Hero (blue/white/green palette via --night, --mist, --white) ===== -->
    <section class="article-hero bg-night">
      <div class="article-wrap">
        <p class="hero-kicker sr-only"><!-- Optional small kicker/category --></p>
        <h1 class="hero-title heading-font">
          <!-- H1: Your Post Title -->
          Gravel Riding in West Michigan: A Beginner’s Guide
        </h1>
        <div class="article-meta">
          <span>By <a href="/about" class="text-accent">Author Name</a></span>
          <span>•</span>
          <time datetime="2025-08-18">August 18, 2025</time>
          <span>•</span>
          <span class="tag">Gravel</span>
          <span class="tag">Michigan</span>
          <span class="tag">Guides</span>
        </div>
      </div>
    </section>

    <!-- ===== Featured Image ===== -->
    <section class="article-wrap" style="margin-top: -3rem;">
      <figure class="feature-img subtle-shadow">
        <img src="https://placeholder.example/1600x900.jpg" alt="Descriptive alt text for featured image" style="width:100%; display:block;" />
        <figcaption style="font-size:.9rem; color:var(--stone); padding:.5rem 1rem;">Optional caption crediting photographer/source.</figcaption>
      </figure>
    </section>

    <!-- ===== Article Body ===== -->
    <article class="article-wrap">
      <!-- Table of Contents (auto-generate with JS if desired) -->
      <aside class="toc" aria-labelledby="toc-title">
        <strong id="toc-title" class="heading-font">On this page</strong>
        <ol>
          <li><a href="#intro">Introduction</a></li>
          <li><a href="#routes">Best Beginner Routes</a></li>
          <li><a href="#gear">Essential Gear</a></li>
          <li><a href="#tips">Safety & Etiquette</a></li>
        </ol>
      </aside>

      <div class="divider" style="margin:1.5rem 0;"></div>

      <div class="prose">
        <h2 id="intro">Introduction</h2>
        <p><!-- Body paragraph: compelling lede using your brand voice. -->Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vivamus luctus, nisi at fermentum mattis, lorem nisi gravida magna, at fringilla felis nisl ut nibh.</p>

        <h2 id="routes">Best Beginner Routes</h2>
        <p>Curate 3–5 routes with surface notes, elevation, and parking tips.</p>
        <ul>
          <li><strong>Route One:</strong> 12 miles, mostly hardpack; family-friendly.</li>
          <li><strong>Route Two:</strong> 20 miles, rolling hills; scenic overlooks.</li>
        </ul>

        <div class="pull-quote">“Design-forward doesn’t mean busy—let whitespace and typography breathe.”</div>

        <h3 id="gear">Essential Gear</h3>
        <p>Helmet, tubeless setup, handheld pump/CO₂, multi-tool, lights, and layered apparel for Michigan swings.</p>

        <h3 id="tips">Safety & Etiquette</h3>
        <p>Ride single file when cars approach, call passes, and leave no trace.</p>
      </div>

      <!-- Inline share + tags -->
      <footer class="article-footer">
        <div class="share" aria-label="Share this article">
          <span>Share:</span>
          <a href="#" aria-label="Share on X/Twitter">X</a>
          <a href="#" aria-label="Share on Facebook">Facebook</a>
          <a href="#" aria-label="Share on LinkedIn">LinkedIn</a>
          <a href="#" aria-label="Copy link">Copy Link</a>
        </div>

        <div class="prev-next">
          <a href="/blog/previous-post" class="card-hover">← Previous</a>
          <a href="/blog/next-post" class="card-hover">Next →</a>
        </div>
      </footer>
    </article>

    <!-- ===== Newsletter CTA (blue/green on dark) ===== -->
    <section class="article-wrap">
      <div class="newsletter subtle-shadow">
        <strong class="heading-font" style="font-size:1.25rem;">Get new posts in your inbox</strong>
        <form action="/subscribe" method="post" class="nav-bar" style="gap:.75rem;">
          <label for="email" class="sr-only">Email address</label>
          <input id="email" type="email" name="email" placeholder="you@domain.com" required />
          <button type="submit" class="btn btn-outline-light">Subscribe</button>
        </form>
      </div>
    </section>
  </main>

  <!-- ===== Global Footer ===== -->
  <footer>
    <div class="article-wrap" style="padding:2rem 1.25rem;">
      <div class="brand heading-font">Site Name</div>
      <div class="rule"></div>
      <p style="margin:.75rem 0 0;">© <span id="year"></span> Site Name. All rights reserved.</p>
    </div>
  </footer>

  <!-- ===== Minimal JS for hamburger + year ===== -->
  <script>
    // Mobile menu toggle (matches .hidden utility in your CSS)
    const toggle = document.getElementById('navToggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(isOpen));
    });

    // Current year in footer
    document.getElementById('year').textContent = new Date().getFullYear();
  </script>
</body>
</html>
