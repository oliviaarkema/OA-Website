<!DOCTYPE html>
<html lang="en">
<head>
  <!-- ===== SEO Basics ===== -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><!-- SEO: 60–65 chars -->Blog Post Title | Olivia Arkema</title>
  <meta name="description" content="<!-- SEO: 150–160 char description for this post. -->" />
  <link rel="canonical" href="https://oliviaarkema.com/blog/your-post-slug" />

  <!-- Open Graph -->
  <meta property="og:type" content="article" />
  <meta property="og:title" content="Blog Post Title | Olivia Arkema" />
  <meta property="og:description" content="Short social summary for this article." />
  <meta property="og:url" content="https://oliviaarkema.com/blog/your-post-slug" />
  <meta property="og:image" content="https://oliviaarkema.com/assets/featured.jpg" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Blog Post Title | Olivia Arkema" />
  <meta name="twitter:description" content="Short social summary." />
  <meta name="twitter:image" content="https://oliviaarkema.com/assets/featured.jpg" />

  <!-- JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "Blog Post Title",
    "description": "Plain-text description.",
    "image": ["https://oliviaarkema.com/assets/featured.jpg"],
    "datePublished": "2025-08-18T12:00:00-04:00",
    "dateModified": "2025-08-18T12:00:00-04:00",
    "author": { "@type": "Person", "name": "Olivia Arkema" },
    "publisher": { "@type": "Organization", "name": "Olivia Arkema" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://oliviaarkema.com/blog/your-post-slug" }
  }
  </script>

  <!-- Styles -->
  <link rel="stylesheet" href="/style.css" />
  <style>
    /* Minimal page-specific helpers (play nice with your style.css) */
    .wrap{ max-width: 980px; margin: 0 auto; padding: 0 1.25rem; }
    .article-hero{ background: linear-gradient(180deg, rgba(35,66,76,.75), rgba(35,66,76,.45)), center/cover no-repeat; min-height: 42vh; display:grid; place-items:center; text-align:center; padding: 7rem 1.25rem 3rem; }
    .hero-title{ color: var(--white); }
    .article-meta{ color: var(--moss); font-size:.95rem; display:flex; gap:.75rem; justify-content:center; flex-wrap:wrap; }
    /* Center the featured image perfectly */
    .feature-img{ margin: -2.75rem auto 1.5rem; max-width: 980px; }
    .feature-img img{ display:block; width:100%; height:auto; border-radius:.75rem; border:2px solid var(--accent); box-shadow: var(--shadow-sm); }
    .prose{ max-width: 68ch; margin: 0 auto; font-size: 1.125rem; line-height: 1.8; }
    .toc{ background: var(--white); border: 2px solid var(--accent); border-radius: .75rem; padding: 1rem 1.25rem; box-shadow: var(--shadow-sm); max-width: 68ch; margin: 1.5rem auto; }
    .pull-quote{ font-size:1.25rem; padding:1rem 1.25rem; border-left:4px solid var(--accent); background: var(--mist); border-radius:.5rem; margin:2rem 0; }
    /* Footer alignment helpers (use existing footer styles in your CSS) */
    footer .footer-grid{ display:grid; gap:1.25rem; grid-template-columns: 1fr; }
    @media (min-width: 768px){ footer .footer-grid{ grid-template-columns: 1.2fr .8fr .8fr; align-items:start; } }

    /* NAV: keep it lean; use your existing classes and ensure right alignment */
    #navbar .nav-bar{ gap: 1rem; }
    #navbar .nav-right{ margin-left: auto; display:flex; align-items:center; gap: 1.25rem; }
    #navbar .nav-links{ display:none; gap:2rem; }
    #navbar .nav-toggle{ display:inline-flex; }
    @media (min-width: 1024px){
      #navbar .nav-links{ display:flex; }
      #navbar .nav-toggle{ display:none; }
    }
  </style>
</head>

<body>
  <!-- ===== Header / Clean Nav ===== -->
  <header id="navbar">
    <div class="nav-bar wrap" style="padding:.75rem 0;">
      <a class="nav-brand" href="/">
        <img class="nav-logo" src="/assets/logo.svg" alt="" />
        Olivia Arkema
      </a>

      <div class="nav-right">
        <nav class="nav-links" aria-label="Primary">
          <a href="/about">About</a>
          <a href="/work-with-me">Work with me</a>
          <a href="/blog" aria-current="page">Blog</a>
          <a href="/contact">Contact</a>
        </nav>

        <!-- Right-aligned hamburger -->
        <button class="nav-toggle" id="navToggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu (hidden by default via .hidden in your CSS) -->
    <nav id="mobile-menu" class="mobile-menu hidden" aria-label="Mobile Primary">
      <div class="wrap" style="padding-bottom:1rem;">
        <a href="/about">About</a>
        <a href="/work-with-me">Work with me</a>
        <a href="/blog">Blog</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>
  </header>

  <main>
    <!-- ===== Hero ===== -->
    <section class="article-hero bg-night">
      <div class="wrap">
        <h1 class="hero-title heading-font">Blog Post Title That’s Clear & Compelling</h1>
        <div class="article-meta">
          <span>By <a href="/about" class="text-accent">Olivia Arkema</a></span>
          <span>•</span>
          <time datetime="2025-08-18">August 18, 2025</time>
          <span>•</span>
          <span>Category</span>
        </div>
      </div>
    </section>

    <!-- ===== Centered Featured Image ===== -->
    <figure class="feature-img">
      <img src="https://via.placeholder.com/1600x900" alt="Descriptive alt text for the featured image" />
      <figcaption class="wrap" style="color:var(--stone); font-size:.9rem; padding:.5rem 0 0;">
        Optional caption or photo credit.
      </figcaption>
    </figure>

    <!-- ===== Article Body ===== -->
    <article class="wrap">
      <aside class="toc" aria-labelledby="toc-title">
        <strong id="toc-title" class="heading-font">On this page</strong>
        <ol>
          <li><a href="#intro">Introduction</a></li>
          <li><a href="#section-1">Key Section</a></li>
          <li><a href="#section-2">Another Section</a></li>
        </ol>
      </aside>

      <div class="prose">
        <h2 id="intro">Introduction</h2>
        <p><!-- Body lede -->Write an engaging first paragraph that sets the context and hooks the reader…</p>

        <h2 id="section-1">Key Section</h2>
        <p>Blue / white / green palette comes through via your CSS variables and accents.</p>

        <div class="pull-quote">“Let whitespace and typography do the heavy lifting.”</div>

        <h3 id="section-2">Another Section</h3>
        <p>Lists, images, and subheads keep scanning easy.</p>
      </div>
    </article>
  </main>

  <!-- ===== Footer (aligned with your homepage styles) ===== -->
  <footer>
    <div class="wrap" style="padding:2rem 0;">
      <div class="footer-grid">
        <!-- Brand / Blurb -->
        <div>
          <div class="brand heading-font" style="font-size:1.25rem;">Olivia Arkema</div>
          <div class="rule"></div>
          <p style="margin:.75rem 0 0; max-width:48ch;">Writer • Maker • Outdoorsy data person. Field notes on gravel, running, and design-forward living.</p>
        </div>

        <!-- Quick links (matches .quick-links in your CSS) -->
        <div class="quick-links">
          <strong class="heading-font" style="display:block; margin-bottom:.5rem;">Quick Links</strong>
          <nav>
            <a href="/about">About</a><br/>
            <a href="/work-with-me">Work with me</a><br/>
            <a href="/blog">Blog</a><br/>
            <a href="/contact">Contact</a>
          </nav>
        </div>

        <!-- Social / Connect (matches .connect in your CSS) -->
        <div class="connect">
          <strong class="heading-font" style="display:block; margin-bottom:.5rem;">Connect</strong>
          <nav>
            <a href="https://instagram.com/yourhandle" rel="me">Instagram</a><br/>
            <a href="https://www.linkedin.com/in/yourprofile/">LinkedIn</a><br/>
            <a href="mailto:hello@oliviaarkema.com">hello@oliviaarkema.com</a>
          </nav>
        </div>
      </div>

      <div style="margin-top:1.25rem; display:flex; justify-content:space-between; gap:.75rem; flex-wrap:wrap; color:var(--stone);">
        <small>© <span id="year"></span> Olivia Arkema. All rights reserved.</small>
        <small><a href="/privacy" style="color:inherit; text-decoration:none;">Privacy</a> • <a href="/terms" style="color:inherit; text-decoration:none;">Terms</a></small>
      </div>
    </div>
  </footer>

  <!-- ===== Minimal JS ===== -->
  <script>
    // Hamburger toggle (uses your .hidden utility)
    const toggle = document.getElementById('navToggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => {
      const isHidden = menu.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(!isHidden));
    });

    // Dynamic year
    document.getElementById('year').textContent = new Date().getFullYear();
  </script>
</body>
</html>
