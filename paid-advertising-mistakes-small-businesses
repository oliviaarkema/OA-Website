  <!-- Copy-to-clipboard toast -->
  <div id="copyToast" role="status" aria-live="polite" hidden
       style="position:fixed;left:50%;bottom:24px;transform:translateX(-50%) translateY(8px);
              background:#5f849c;color:#fff;padding:.6rem .9rem;border-radius:9999px;
